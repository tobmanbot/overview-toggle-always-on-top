msgid "📌 Always on Top"
msgstr "📌 Alltid øverst"

msgid "PiP Settings"
msgstr "PiP-innstillinger"

msgid "PiP Start Position"
msgstr "PiP-startposisjon"

msgid "Where the PiP window is moved when opened."
msgstr "Hvor PiP-vinduet flyttes når det åpnes."

msgid "None (don't move)"
msgstr "Ingen (ikke flytt)"

msgid "Top Left"
msgstr "Øverst til venstre"

msgid "Top Right"
msgstr "Øverst til høyre"

msgid "Bottom Left"
msgstr "Nederst til venstre"

msgid "Bottom Right"
msgstr "Nederst til høyre"

msgid "Center"
msgstr "Midten"

msgid "Position"
msgstr "Posisjon"

msgid "Distance from Screen Edge"
msgstr "Avstand fra skjermkant"

msgid "Pixel distance to edges (only when position is set)"
msgstr "Pikselavstand til kanter (kun når posisjon er angitt)"

msgid "PiP Start Size"
msgstr "PiP-startstørrelse"

msgid ""
"Size to set a new PiP window to when opened.\n"
"Pixel override takes precedence over percentage. 0 = disabled."
msgstr ""
"Størrelse som et nytt PiP-vindu settes til ved åpning.\n"
"Piksel-overstyring har forrang over prosent. 0 = deaktivert."

msgid "Size as % of Screen Width"
msgstr "Størrelse som % av skjermbredde"

msgid "0 = disabled • Recommended: 20–30 %"
msgstr "0 = deaktivert • Anbefalt: 20–30 %"

msgid "Fixed Width in Pixels (Override)"
msgstr "Fast bredde i piksler (overstyring)"

msgid "0 = disabled • Takes precedence over percentage"
msgstr "0 = deaktivert • Har forrang over prosent"

msgid "Height"
msgstr "Høyde"

msgid "Always proportional to set width (original aspect ratio)."
msgstr "Alltid proporsjonal med angitt bredde (originalt sideforhold)."

msgid "Custom PiP Window Titles (Optional)"
msgstr "Egendefinerte PiP-vinduestitler (valgfritt)"

msgid ""
"Only needed if your browser uses a PiP window title not recognized "
"automatically.\n"
"The extension already covers 15 languages built-in — most users can leave "
"this empty."
msgstr ""
"Bare nødvendig hvis nettleseren din bruker en PiP-vinduestitel som ikke "
"gjenkjennes automatisk.\n"
"Utvidelsen støtter allerede 15 språk — de fleste brukere kan la dette "
"feltet stå tomt."

msgid "Add title fragment…"
msgstr "Legg til titelfragment…"

msgid "Remove"
msgstr "Fjern"
